# ==============================================================================
# AGENTOPS ENVIRONMENT VARIABLES CONFIGURATION TEMPLATE
# Copy this file to .env and configure the values for your environment.
# Never commit the actual .env file with production secrets to version control.
# ==============================================================================

# --- PLATFORM CONFIGURATION ---
PLATFORM_ENV=development # development | staging | production
PLATFORM_PORT=8000
LOG_LEVEL=INFO

# --- PRIMARY COGNITIVE CORE & LLM PROVIDERS ---
# Anthropic is the primary provider for high-reasoning orchestration pipelines.
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI is utilized for high-throughput micro-agent routing.
OPENAI_API_KEY=your-openai-api-key-here

# AWS Bedrock used as a robust fallback for enterprise clients.
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1

# --- MEMORY SUBSYSTEM & DATABASES ---
# Relational DB for platform configurations, user credentials, and structured session logs.
POSTGRES_URL=postgresql://agentops_user:agentops_password@localhost:5432/agentops_db

# Memory storage: Episodic, sliding window buffers, task-level caching.
REDIS_URL=redis://localhost:6379/0

# Document/NoSQL database for unstructured execution graphs, trace records, and raw JSON payloads.
MONGODB_URI=mongodb://localhost:27017/agentops_metadata

# Vector Databases for semantic lookup and long-term memory retrieval.
# In Production, Pinecone is our managed standard.
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_ENV=us-east-1-gcp
PINECONE_INDEX_NAME=agentops-memory-index

# Local alternative to Pinecone, configured inside the local dev stack.
QDRANT_URL=http://localhost:6333

# --- EVENT STREAMING AND BUS ---
# Kafka cluster endpoints for orchestrating distributed, asynchronous workflows.
KAFKA_BROKER_URL=localhost:9092

# --- OBJECT STORAGE (ARTIFACTS) ---
# S3/MinIO compatible object store for task runtime files, screenshots, and logs.
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=agentops_minio_admin
MINIO_SECRET_KEY=agentops_minio_secret
MINIO_BUCKET_NAME=agent-artifacts
MINIO_USE_SSL=false

# --- SYSTEM INTEGRATIONS & ACTIONS ---
GITHUB_TOKEN=your-github-personal-access-token
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/here

# --- OBSERVABILITY & DISTRIBUTED TRACING ---
# OpenTelemetry configuration for end-to-end tracing.
OTEL_SERVICE_NAME=agentops-platform
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
